---
import Layout from "../layouts/PageLayout.astro";
import { AvatarCirclesDemo } from "@/components/avatars";
import { ParticlesHero } from "@/components/particles-hero";
import { ArrowRight, Database, Filter, Sparkles, Mail, Cpu, Upload, Download, Zap, Shield } from "lucide-react";
import { HERO, PRICING, METADATA } from "../consts";
---
<Layout
	metadata={{
		title: HERO.headline,
		description: METADATA.description,
	}}
>
	<section class="relative overflow-hidden py-20 md:py-32">
		<ParticlesHero client:load />
		<div class="container relative z-10 flex flex-col items-center justify-center text-center">
			<div class="max-w-2xl">
				{HERO.showAvatars && (
					<div class="flex justify-center mb-6">
						<AvatarCirclesDemo client:load />
					</div>
				)}
				<p class="text-sm text-muted-foreground mb-4">{HERO.badge}</p>
				<h1 class="text-4xl md:text-6xl font-bold tracking-tight text-foreground pb-1">{HERO.headline}</h1>
				<p class="py-8 text-lg text-muted-foreground">{HERO.subheadline}</p>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a href={HERO.primaryCta.href || import.meta.env.PUBLIC_APP_URL} class="inline-flex items-center justify-center whitespace-nowrap rounded-xl text-base font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-12 px-8 py-3 w-full sm:w-auto">
						{HERO.primaryCta.label}
						<ArrowRight className="h-4 w-4 ml-2" />
					</a>
					<a href={HERO.secondaryCta.href} class="inline-flex items-center justify-center whitespace-nowrap rounded-xl text-base font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 border border-primary text-primary bg-background hover:bg-accent hover:text-accent-foreground h-12 px-8 py-3 w-full sm:w-auto">
						{HERO.secondaryCta.label}
					</a>
				</div>
			</div>
		</div>
	</section>
	
	<section id="features" class="py-12 md:py-16">
		<div class="container">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4">Powerful Features</h2>
				<p class="text-lg text-muted-foreground">Everything you need to achieve your goals</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
				<div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
					<div class="flex flex-col space-y-4 p-6">
						<div class="p-2 w-fit rounded-lg bg-primary/10">
							<Database className="h-6 w-6 text-primary" />
						</div>
						<div class="space-y-1.5">
							<h3 class="font-semibold leading-none tracking-tight mb-2">Feature One</h3>
							<p class="text-sm text-muted-foreground">Describe what this feature does and how it helps users.</p>
						</div>
					</div>
				</div>
				<div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
					<div class="flex flex-col space-y-4 p-6">
						<div class="p-2 w-fit rounded-lg bg-primary/10">
							<Filter className="h-6 w-6 text-primary" />
						</div>
						<div class="space-y-1.5">
							<h3 class="font-semibold leading-none tracking-tight mb-2">Feature Two</h3>
							<p class="text-sm text-muted-foreground">Describe what this feature does and how it helps users.</p>
						</div>
					</div>
				</div>
				<div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
					<div class="flex flex-col space-y-4 p-6">
						<div class="p-2 w-fit rounded-lg bg-primary/10">
							<Sparkles className="h-6 w-6 text-primary" />
						</div>
						<div class="space-y-1.5">
							<h3 class="font-semibold leading-none tracking-tight mb-2">Feature Three</h3>
							<p class="text-sm text-muted-foreground">Describe what this feature does and how it helps users.</p>
						</div>
					</div>
				</div>
				<div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
					<div class="flex flex-col space-y-4 p-6">
						<div class="p-2 w-fit rounded-lg bg-primary/10">
							<Mail className="h-6 w-6 text-primary" />
						</div>
						<div class="space-y-1.5">
							<h3 class="font-semibold leading-none tracking-tight mb-2">Feature Four</h3>
							<p class="text-sm text-muted-foreground">Describe what this feature does and how it helps users.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="workflows" class="bg-muted/50 py-16 md:py-24">
		<div class="container">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4">How It Works</h2>
				<p class="text-lg text-muted-foreground">Get started in three simple steps</p>
			</div>
			<div class="max-w-5xl mx-auto relative">
				<div class="hidden md:block absolute top-10 left-[16%] right-[16%] h-px bg-border -z-10 border-t border-dashed border-border"></div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
					<div class="flex flex-col items-center text-center relative">
						<div class="relative bg-card border border-border rounded-xl p-4 shadow-sm mb-6 w-20 h-20 flex items-center justify-center">
							<Upload className="h-8 w-8 text-foreground" />
							<div class="absolute -top-3 -right-3 w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold text-sm border-2 border-background">1</div>
						</div>
						<h3 class="text-xl font-bold mb-3">Step One</h3>
						<p class="text-muted-foreground text-sm leading-relaxed max-w-xs">Describe what happens in the first step.</p>
					</div>
					<div class="flex flex-col items-center text-center relative">
						<div class="relative bg-card border border-border rounded-xl p-4 shadow-sm mb-6 w-20 h-20 flex items-center justify-center">
							<Cpu className="h-8 w-8 text-foreground" />
							<div class="absolute -top-3 -right-3 w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold text-sm border-2 border-background">2</div>
						</div>
						<h3 class="text-xl font-bold mb-3">Step Two</h3>
						<p class="text-muted-foreground text-sm leading-relaxed max-w-xs">Describe what happens in the second step.</p>
					</div>
					<div class="flex flex-col items-center text-center relative">
						<div class="relative bg-card border border-border rounded-xl p-4 shadow-sm mb-6 w-20 h-20 flex items-center justify-center">
							<Download className="h-8 w-8 text-foreground" />
							<div class="absolute -top-3 -right-3 w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold text-sm border-2 border-background">3</div>
						</div>
						<h3 class="text-xl font-bold mb-3">Step Three</h3>
						<p class="text-muted-foreground text-sm leading-relaxed max-w-xs">Describe the final result.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="py-16 md:py-24">
		<div class="container">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4">Why Choose Us?</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
				<div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
					<div class="flex flex-col space-y-4 p-8">
						<div class="p-2 w-fit rounded-lg bg-muted">
							<Zap className="h-5 w-5 text-foreground" />
						</div>
						<div class="space-y-2">
							<h3 class="font-bold text-lg leading-none tracking-tight">Fast & Efficient</h3>
							<p class="text-sm text-muted-foreground leading-relaxed">Describe why your product is fast.</p>
						</div>
					</div>
				</div>
				<div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
					<div class="flex flex-col space-y-4 p-8">
						<div class="p-2 w-fit rounded-lg bg-muted">
							<Shield className="h-5 w-5 text-foreground" />
						</div>
						<div class="space-y-2">
							<h3 class="font-bold text-lg leading-none tracking-tight">Secure & Reliable</h3>
							<p class="text-sm text-muted-foreground leading-relaxed">Describe your security features.</p>
						</div>
					</div>
				</div>
				<div class="rounded-xl border border-border bg-card text-card-foreground shadow-sm">
					<div class="flex flex-col space-y-4 p-8">
						<div class="p-2 w-fit rounded-lg bg-muted">
							<Sparkles className="h-5 w-5 text-foreground" />
						</div>
						<div class="space-y-2">
							<h3 class="font-bold text-lg leading-none tracking-tight">Easy to Use</h3>
							<p class="text-sm text-muted-foreground leading-relaxed">Describe how easy it is.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="pricing" class="bg-muted/50 py-12 md:py-16">
		<div class="container">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-4">{PRICING.title}</h2>
				<p class="text-lg text-muted-foreground">{PRICING.subtitle}</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
				{PRICING.tiers.map((tier) => (
					<div class={`rounded-xl border ${tier.highlighted ? 'border-primary shadow-md' : 'border-border shadow-sm'} bg-card text-card-foreground flex flex-col p-6 relative`}>
						{tier.badge && (
							<div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-primary-foreground px-3 py-1 rounded-full text-xs font-medium">{tier.badge}</div>
						)}
						<h3 class="text-xl font-semibold mb-2">{tier.name}</h3>
						<div class="flex items-baseline gap-2 mb-4">
							<span class="text-3xl font-bold">
								{tier.price === 0 ? '$0' : `$${tier.price}`}
								{tier.price > 0 && <span class="text-base font-normal text-muted-foreground">/{tier.period}</span>}
							</span>
							{tier.originalPrice && (
								<span class="text-lg text-muted-foreground line-through">${tier.originalPrice}</span>
							)}
						</div>
						<p class="text-sm text-muted-foreground mb-6">{tier.description}</p>
						<ul class="space-y-3 mb-6 flex-1">
							{tier.features.map((feature) => (
								<li class="flex items-center text-sm"><span class="mr-2 text-primary">✓</span> {feature}</li>
							))}
						</ul>
						<a href={tier.cta.href || import.meta.env.PUBLIC_APP_URL} class={`inline-flex items-center justify-center whitespace-nowrap rounded-xl text-base font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 h-12 px-8 py-3 w-full ${tier.highlighted ? 'bg-primary text-primary-foreground hover:bg-primary/90' : 'border border-primary text-primary bg-background hover:bg-accent hover:text-accent-foreground'}`}>
							{tier.cta.label}
						</a>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>
