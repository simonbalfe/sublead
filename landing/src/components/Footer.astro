---
import { SITE_TITLE, METADATA } from '../consts';

const currentYear = new Date().getFullYear();
const twitterHandle = METADATA.twitter.handle.replace('@', '');
---

<footer class="mt-auto bg-primary text-primary-foreground border-t border-primary-foreground/10 pt-16 md:pt-24">
  <div class="container">
    <div class="py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="md:col-span-1">
          <a href="/" class="flex items-center space-x-2 text-xl font-bold hover:opacity-80 transition-opacity">
            <span>{SITE_TITLE}</span>
          </a>
          <p class="mt-3 text-primary-foreground/80 max-w-md">
            {METADATA.description}
          </p>
        </div>

        <div>
          <h3 class="font-semibold mb-4">Product</h3>
          <ul class="space-y-3 text-primary-foreground/70">
            <li><a href="/#features" class="hover:text-primary-foreground transition-colors">Features</a></li>
            <li><a href="/#workflows" class="hover:text-primary-foreground transition-colors">Workflows</a></li>
            <li><a href="/#pricing" class="hover:text-primary-foreground transition-colors">Pricing</a></li>
          </ul>
        </div>

        <div>
          <h3 class="font-semibold mb-4">Resources</h3>
          <ul class="space-y-3 text-primary-foreground/70">
            <li><a href="/blog" class="hover:text-primary-foreground transition-colors">Blog</a></li>
            <li><a href="/privacy" class="hover:text-primary-foreground transition-colors">Privacy Policy</a></li>
          </ul>
        </div>

        <div>
          <h3 class="font-semibold mb-4">Social</h3>
          <ul class="space-y-3 text-primary-foreground/70">
            <li>
              <a 
                href={`https://x.com/${twitterHandle}`} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="hover:opacity-80 transition-opacity inline-block"
              >
                <img src="/x.svg" alt="X (formerly Twitter)" class="w-6 h-6" />
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-primary-foreground/10 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-primary-foreground/60 text-sm">
          &copy; {currentYear} {SITE_TITLE}. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
