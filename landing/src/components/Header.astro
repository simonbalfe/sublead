---
import { SITE, NAVIGATION } from '../consts';

export interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<header class={`sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60 ${className}`}>
  <div class="container flex h-16 items-center">
    <!-- Left: Logo -->
    <div class="flex flex-1 items-center">
      <a href="/" class="flex items-center gap-2">
        <img src={SITE.logo} alt={`${SITE.name} Logo`} class="w-8 h-8 rounded-lg" />
        <span class="text-xl font-bold tracking-tight">{SITE.name}</span>
      </a>
    </div>

    <!-- Center: Desktop Navigation -->
    <nav class="hidden md:flex items-center justify-center gap-8 text-sm font-medium text-muted-foreground">
      {NAVIGATION.links.map((link) => (
        <a href={link.href} class="transition-colors hover:text-foreground">{link.label}</a>
      ))}
    </nav>

    <!-- Right Side: Actions -->
    <div class="flex flex-1 items-center justify-end gap-4">
      <div class="hidden md:flex items-center gap-6">
        <a href={import.meta.env.PUBLIC_APP_URL} class="text-sm font-semibold hover:text-foreground/80 transition-colors">
          {NAVIGATION.loginLabel}
        </a>
        <a href={NAVIGATION.cta.href || import.meta.env.PUBLIC_APP_URL} class="inline-flex items-center justify-center whitespace-nowrap rounded-xl text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-6 py-2">
          {NAVIGATION.cta.label}
        </a>
      </div>

      <!-- Mobile Dropdown -->
      <div class="md:hidden relative">
        <button id="mobile-menu-button" class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 hover:bg-accent hover:text-accent-foreground h-10 w-10">
          <span class="sr-only">Toggle menu</span>
          ☰
        </button>
        <div id="mobile-menu-dropdown" class="absolute right-0 top-full mt-2 w-[calc(100vw-2rem)] sm:w-56 origin-top-right rounded-md border bg-popover p-1 text-popover-foreground shadow-md outline-none animate-in fade-in-0 zoom-in-95 hidden mr-4 sm:mr-0">
          <div class="grid gap-1 p-2">
            {NAVIGATION.links.map((link) => (
              <a href={link.href} class="block select-none space-y-1 rounded-md p-3 leading-none no-underline outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground">{link.label}</a>
            ))}
            <hr class="my-2 border-border" />
            <a href={import.meta.env.PUBLIC_APP_URL} class="block select-none space-y-1 rounded-md p-3 leading-none no-underline outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground">{NAVIGATION.loginLabel}</a>
            <a href={NAVIGATION.cta.href || import.meta.env.PUBLIC_APP_URL} class="block select-none space-y-1 rounded-md p-3 leading-none no-underline outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground font-semibold text-primary">{NAVIGATION.cta.label}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenuDropdown = document.getElementById('mobile-menu-dropdown');

  if (mobileMenuButton && mobileMenuDropdown) {
    mobileMenuButton.addEventListener('click', (e) => {
      e.stopPropagation();
      mobileMenuDropdown.classList.toggle('hidden');
    });

    document.addEventListener('click', (e) => {
      if (!mobileMenuDropdown.contains(e.target as Node) && !mobileMenuButton.contains(e.target as Node)) {
        mobileMenuDropdown.classList.add('hidden');
      }
    });
  }
</script>
